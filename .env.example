# Copy to `.env` in the directory you run scripts from (repo root is fine) and fill in.
# Never commit the real `.env` — credentials only, no secrets in scripts.

# --- Direct RDS/Postgres connection (bypasses PgBouncer) ---
PGHOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
PGPORT=5432
PGUSER=your_pg_user
PGPASSWORD=your_pg_password
PGDATABASE=your_database

# --- PgBouncer admin console (only needed for connection-exhaustion drills) ---
PGBOUNCER_HOST=your-pgbouncer-endpoint.us-east-1.elb.amazonaws.com
PGBOUNCER_PORT=5432
PGBOUNCER_ADMIN_USER=your_pgbouncer_admin_user
PGBOUNCER_ADMIN_PASSWORD=your_pgbouncer_admin_password

# --- Dedicated drill role (only needed for role-connection-limit drills) ---
DRILL_ROLE=drill_role
DRILL_ROLE_PASSWORD=your_drill_role_password

# --- Set to 1 to skip the typed "yes" confirmation prompt (agent/CI mode) ---
DRILL_YES=1
